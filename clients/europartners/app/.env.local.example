# ============================================================
# EUROPARTNERS — Variables de Entorno
# Copiar a .env.local y completar con valores reales
# ============================================================

# Supabase (obtener en app.supabase.com > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Claude API (obtener en console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend — obtener en resend.com). Los destinatarios (Marta, Deisy) se
# leen de usuarios.email en Supabase, no de variables de entorno.
RESEND_API_KEY=re_...
EMAIL_FROM=Europartners <notificaciones@egispty.com>

# URL de la app (cambiar según entorno)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Solo para script de migración (ruta local al OneDrive)
ONEDRIVE_LOCAL_PATH=C:/Users/Jeronimo/OneDrive/EUROPARTNERS/CHINA/THANSHAN/JAMAICA
